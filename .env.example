# MongoDB Atlas (required for real app — get from https://cloud.mongodb.com)
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/dukaanbot?retryWrites=true&w=majority"

# Frontend (Next.js :3000)
NEXT_PUBLIC_API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# Backend (Express :4000)
BACKEND_PORT="4000"
JWT_SECRET="change-me-to-a-random-32-char-secret"

# Internal worker ↔ app communication
INTERNAL_API_SECRET="dev-internal-secret-change-me-32chars"
SESSION_ENCRYPTION_KEY="01234567890123456789012345678901"
WHATSAPP_WORKER_URL="http://localhost:3001"
APP_URL="http://localhost:4000"
WHATSAPP_WORKER_PORT="3001"

# Stripe (optional — add keys from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

# Google OAuth (optional, not wired yet)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
