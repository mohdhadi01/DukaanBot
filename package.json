{
  "name": "dukaanbot",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --cwd frontend build",
    "start": "concurrently \"bun run start:frontend\" \"bun run start:backend\"",
    "start:frontend": "bun run --cwd frontend start",
    "start:backend": "bun run --cwd backend start",
    "worker:whatsapp": "bun run --cwd backend worker:dev",
    "lint": "bun run --cwd frontend lint",
    "install:all": "bun install && bun install --cwd frontend && bun install --cwd backend"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@vercel/node": "^5.3.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "mongoose": "^8.19.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "serverless-http": "^3.2.0",
    "stripe": "^22.2.3",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^10.0.3"
  }
}
