{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "bun run install:all",
  "buildCommand": "bun run build",
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/next" },
    { 
      "src": "api/index.ts", 
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "memory": 1024
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/health", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
